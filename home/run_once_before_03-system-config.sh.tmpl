#!/usr/bin/env bash
set -euo pipefail

{{ if eq .chezmoi.osRelease.id "fedora" -}}

echo "==> Configuring sshd (default port 22, password + key auth allowed, no root)"
sudo tee /etc/ssh/sshd_config.d/50-local.conf >/dev/null <<'EOF'
# Managed by chezmoi (run_once_before_03-system-config.sh.tmpl)
# No explicit Port line — sshd listens on the default 22.
# Password auth is enabled to allow bootstrapping access before pubkeys
# are uploaded to ~/.ssh/authorized_keys. After you've added your trusted
# client pubkey(s), consider flipping PasswordAuthentication to "no" for
# stronger security.
PasswordAuthentication yes
PubkeyAuthentication yes
PermitRootLogin no
ChallengeResponseAuthentication no
EOF

echo "==> Ensuring firewalld allows the ssh service (port 22)"
sudo firewall-cmd --permanent --add-service=ssh
sudo firewall-cmd --reload

echo "==> Enabling sshd"
sudo systemctl enable --now sshd
sudo systemctl restart sshd

echo "==> Disabling GNOME auto-suspend for current user"
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type 'nothing'
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-ac-timeout 0
gsettings set org.gnome.settings-daemon.plugins.power sleep-inactive-battery-type 'nothing' 2>/dev/null || true
gsettings set org.gnome.desktop.session idle-delay 0
gsettings set org.gnome.desktop.screensaver lock-enabled false
gsettings set org.gnome.desktop.screensaver idle-activation-enabled false

echo "==> Disabling suspend on GDM lock screen (system-wide)"
sudo mkdir -p /etc/dconf/db/gdm.d
sudo tee /etc/dconf/db/gdm.d/10-power >/dev/null <<'EOF'
[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-type='nothing'
sleep-inactive-ac-timeout=uint32 0
sleep-inactive-battery-type='nothing'
idle-dim=false

[org/gnome/desktop/session]
idle-delay=uint32 0
EOF
sudo dconf update

echo "==> Enabling GDM auto-login for user '$USER'"
sudo install -m 0644 -D /dev/null /etc/gdm/custom.conf.new
sudo tee /etc/gdm/custom.conf >/dev/null <<EOF
# Managed by chezmoi (run_once_before_03-system-config.sh.tmpl)
[daemon]
AutomaticLoginEnable=True
AutomaticLogin=${USER}
WaylandEnable=true

[security]

[xdmcp]

[chooser]

[debug]
EOF

echo "==> System config complete. A reboot is required for auto-login + GDM dconf changes."
{{ end -}}

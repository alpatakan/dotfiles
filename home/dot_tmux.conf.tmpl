{{- /* tmux needs named colors (cyan) or colourN — normalize bare integers */ -}}
{{- $accent := .accent_color -}}
{{- if regexMatch "^[0-9]+$" $accent -}}{{- $accent = printf "colour%s" $accent -}}{{- end -}}
# remap prefix from 'C-b' to 'C-a'
unbind C-b
set-option -g prefix C-a
bind-key C-a send-prefix

# split panes using | and -
bind | split-window -h -c '#{pane_current_path}'
bind - split-window -v  -c '#{pane_current_path}'
unbind '"'
unbind %

# reload config file
bind r source-file ~/.tmux.conf \; display "reloaded ~/.tmux.conf"

# switch panes using Alt-arrow without prefix
bind -n M-Left  select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up    select-pane -U
bind -n M-Down  select-pane -D

# mouse
set -g mouse on

# vi keys in copy mode
setw -g mode-keys vi
bind-key -T copy-mode-vi 'v' send -X begin-selection
bind-key -T copy-mode-vi 'y' send -X copy-selection-and-cancel

# history
set-option -g history-limit 100000

# default shell
set-option -g default-shell /bin/zsh

# true color + modern terminal
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc,ghostty:Tc"

######################
### DESIGN CHANGES ###
######################

# status bar
set -g status-justify left
set -g status-interval 2
set -g status-position bottom
set -g status-style bg=colour234,fg=colour137,dim
set -g status-left '#[fg={{ $accent }},bold] #S #[fg=colour241]│ '
set -g status-left-length 40
set -g status-right '#{?client_prefix,#[bg=colour166#,fg=colour232#,bold] PREFIX ,}#[fg=colour245]#(test -n "$SSH_CONNECTION" && echo " SSH ")#[fg=colour248] #(whoami)@#H #[fg=colour233,bg=colour241,bold] %d/%m #[fg=colour233,bg=colour245,bold] %H:%M:%S '
set -g status-right-length 120

# messages
set -g message-style fg=colour232,bg=colour166,bold
set -g message-command-style fg=blue,bg=black

# window status
setw -g window-status-style bg=colour235,fg=colour138
setw -g window-status-format ' #I#[fg=colour237]:#[fg=colour250]#W#[fg=colour244]#F '
setw -g window-status-current-style bg=colour238,fg={{ $accent }},bold
setw -g window-status-current-format ' #I#[fg=colour250]:#[fg=colour255]#W#[fg={{ $accent }}]#F '
setw -g window-status-bell-style bold,fg=colour255,bg=colour1

# panes
set -g pane-border-style fg=colour238
set -g pane-active-border-style fg={{ $accent }}

# modes
setw -g clock-mode-colour colour135
setw -g mode-style fg=colour196,bg=colour238,bold

# silence
set-option -g visual-activity off
set-option -g visual-bell off
set-option -g visual-silence off
set-window-option -g monitor-activity off
set-option -g bell-action none

# ---------- plugins (TPM) ----------
# Declare TMUX_PLUGIN_MANAGER_PATH up-front so it's set even on first run
# before tpm has been cloned, and so install_plugins can find it headlessly.
set-environment -g TMUX_PLUGIN_MANAGER_PATH "~/.tmux/plugins/"

# clipboard (tmux-yank handles wl-copy / xclip / xsel / OSC 52 automatically)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-yank'

# keep this line last — initializes TPM
run '~/.tmux/plugins/tpm/tpm'
